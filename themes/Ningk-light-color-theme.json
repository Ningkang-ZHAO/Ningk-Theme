  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#A0A1A7",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": {
        "foreground": "#58798B"
      }
    },
    {
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#C87962"
      }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier", "keyword.control"],
      "settings": {
        "foreground": "#C85E63"
      }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call"],
      "settings": {
        "foreground": "#4F6F9A"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
      "settings": {
        "foreground": "#B66B50"
      }
    },
    {
      "scope": ["variable", "meta.object-literal.key"],
      "settings": {
        "foreground": "#383A42"
      }
    },
    {
      "scope": ["variable.parameter", "meta.function.parameters"],
      "settings": {
        "foreground": "#C85E63"
      }
    },
    {
      "scope": ["constant.language", "constant.character", "constant.other"],
      "settings": {
        "foreground": "#3F7F80"
      }
    },
    {
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": {
        "foreground": "#C85E63"
      }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#C87962"
      }
    },
    {
      "scope": ["keyword.operator", "keyword.operator.assignment", "keyword.operator.comparison", "keyword.operator.logical"],
      "settings": {
        "foreground": "#3F7F80"
      }
    },
    {
      "scope": ["constant.character.escape", "string.regexp", "string.regexp punctuation"],
      "settings": {
        "foreground": "#3F7F80"
      }
    },
    {
      "scope": ["support.constant", "support.variable", "variable.language"],
      "settings": {
        "foreground": "#3F7F80"
      }
    },
    {
      "scope": ["meta.import keyword", "meta.export keyword", "keyword.control.import", "keyword.control.from", "keyword.control.export"],
      "settings": {
        "foreground": "#C85E63"
      }
    },
    {
      "scope": ["support.type.property-name.css", "meta.property-name.css", "support.type.vendored.property-name.css"],
      "settings": {
        "foreground": "#4F6F9A"
      }
    },
    {
      "scope": ["punctuation", "meta.brace", "meta.delimiter"],
      "settings": {
        "foreground": "#696B72"
      }
    },
    {
      "scope": ["markup.heading", "markup.heading entity.name", "punctuation.definition.heading.markdown"],
      "settings": {
        "foreground": "#6B737B",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.heading.1.markdown", "markup.heading.1.markdown entity.name"],
      "settings": {
        "foreground": "#557A95",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.heading.2.markdown", "markup.heading.2.markdown entity.name"],
      "settings": {
        "foreground": "#C46F5A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.heading.3.markdown", "markup.heading.3.markdown entity.name"],
      "settings": {
        "foreground": "#58798B",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.heading.4.markdown", "markup.heading.4.markdown entity.name"],
      "settings": {
        "foreground": "#B66B50",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.heading.5.markdown", "markup.heading.5.markdown entity.name"],
      "settings": {
        "foreground": "#3F7F80",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.heading.6.markdown", "markup.heading.6.markdown entity.name"],
      "settings": {
        "foreground": "#756D64",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#C85E63",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#C87962",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.fenced_code.block",
        "markup.raw.block",
        "markup.raw.block.markdown"
      ],
      "settings": {
        "foreground": "#58798B"
      }
    },
    {
      "scope": [
        "markup.inline.raw.markdown",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#B9565F",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "punctuation.definition.raw.markdown",
        "punctuation.definition.raw.begin.markdown",
        "punctuation.definition.raw.end.markdown"
      ],
      "settings": {
        "foreground": "#91474E"
      }
    },
    {
      "scope": ["markup.quote", "markup.quote.markdown", "punctuation.definition.quote.begin.markdown"],
      "settings": {
        "foreground": "#7A6F63",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.definition.list.begin.markdown",
        "punctuation.definition.list.begin.markdown markup.list.numbered",
        "punctuation.definition.list.begin.markdown markup.list.unnumbered"
      ],
      "settings": {
        "foreground": "#B36B33"
      }
    },
    {
      "scope": ["markup.underline.link", "string.other.link"],
      "settings": {
        "foreground": "#557A95",
        "fontStyle": "underline"
      }
    },
    {
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#C85E63",
        "fontStyle": "underline"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#B66B50",
    "interface": "#B66B50",
    "struct": "#B66B50",
    "enum": "#B66B50",
    "type": "#B66B50",
    "typeParameter": "#B66B50",
    "function": "#4F6F9A",
    "method": "#4F6F9A",
    "parameter": "#C85E63",
    "property": "#383A42",
    "variable.readonly": "#3F7F80",
    "enumMember": "#3F7F80",
    "decorator": "#C87962"
  }
}



