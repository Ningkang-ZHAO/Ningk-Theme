      "settings": {
        "foreground": "#4FA3A5",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.heading.6.markdown",
        "markup.heading.6.markdown entity.name",
        "punctuation.definition.heading.markdown markup.heading.6"
