    {
      "scope": [
        "constant.other.reference.link.markdown"
      ],
      "settings": {
        "foreground": "#D98B72"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#E56B6F",
        "fontStyle": "underline"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#E2A07E",
    "interface": "#E2A07E",
    "struct": "#E2A07E",
    "enum": "#E2A07E",
    "type": "#E2A07E",
    "typeParameter": "#E2A07E",
