  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#5C6370",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#89A6B8"
      }
    },
    {
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#D98B72"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "keyword.control"
      ],
      "settings": {
        "foreground": "#E56B6F",
        "fontStyle": ""
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#4F7CAC"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#E2A07E"
      }
    },
    {
      "scope": [
        "variable",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#D7DAE0"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters"
      ],
      "settings": {
        "foreground": "#E56B6F"
      }
    },
    {
      "scope": [
        "constant.language",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#4FA3A5"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#E56B6F"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#D98B72"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#4FA3A5"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "string.regexp",
        "string.regexp punctuation"
      ],
      "settings": {
        "foreground": "#4FA3A5"
      }
    },
    {
      "scope": [
        "support.constant",
        "support.variable",
        "variable.language"
      ],
      "settings": {
        "foreground": "#4FA3A5"
      }
    },
    {
      "scope": [
        "meta.import keyword",
        "meta.export keyword",
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.export"
      ],
      "settings": {
        "foreground": "#E56B6F"
      }
    },
    {
      "scope": [
        "support.type.property-name.css",
