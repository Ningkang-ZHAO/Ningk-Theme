    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#E56B6F",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#D98B72",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#89A6B8"
      }
    },
    {
      "scope": [
        "markup.inline.raw.markdown",
        "markup.inline.raw"
      ],
      "settings": {
        "foreground": "#E58A91",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "punctuation.definition.raw.markdown",
        "punctuation.definition.raw.begin.markdown",
        "punctuation.definition.raw.end.markdown"
      ],
      "settings": {
        "foreground": "#C96F76"
