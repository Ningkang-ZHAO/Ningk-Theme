      ],
      "settings": {
        "foreground": "#77736D",
        "fontStyle": "strikethrough"
      }
    },
    {
      "scope": [
        "meta.separator.markdown"
      ],
      "settings": {
        "foreground": "#57534E"
      }
    },
    {
      "scope": [
        "markup.raw.block",
        "markup.raw.block.markdown",
        "punctuation.definition.markdown"
      ],
      "settings": {
        "foreground": "#89A6B8"
      }
    },
    {
      "scope": [
        "meta.link.inline.markdown",
        "meta.image.inline.markdown"
      ],
      "settings": {
